{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zoo",
  "version": "0.1.0",
  "identifier": "com.ursalaboratories.zoo",
  "build": {
    "beforeDevCommand": "cd frontend && npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd frontend && npm run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Zoo",
        "width": 1280,
        "height": 900,
        "minWidth": 960,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "externalBin": ["binaries/zoo-backend"],
    "resources": []
  }
}
